  <CheatEntries>
    <CheatEntry>
      <ID>87545</ID>
      <Description>"Halo Reach"</Description>
      <Options moHideChildren="1"/>
      <LastState Value="" RealAddress="00000000"/>
      <GroupHeader>1</GroupHeader>
      <CheatEntries>
        <CheatEntry>
          <ID>97723</ID>
          <Description>"Godmode"</Description>
          <Options moHideChildren="1"/>
          <LastState/>
          <Color>FF0080</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{ Game   : MCCWinStore-Win64-Shipping.exe
  Version: 
  Date   : 2024-08-24
  Author : Nathan

  This script does blah blah blah
}

[ENABLE]
aobscanmodule(INJECT,haloreach.dll,F3 41 0F 11 45 10) // should be unique
alloc(newmem,$1000,INJECT)
alloc(onehitflag,4)
label(code)
label(return)
label(check_onehit)
label(onehit)

newmem:
  cmp r10,5
  je invincible
  jmp check_onehit

invincible:
movss xmm0,[ZZSAZ]
jmp code

ZZSAZ:
dd (float)999999999

check_onehit:
  cmp dword ptr [onehitflag], 1
  je onehit
  jmp code

onehit:
  movss xmm0,[ZZSA]
  jmp code

ZZSA:
  dd (float)0

code:
  movss [r13+10],xmm0
  jmp return

INJECT:
  jmp newmem
  nop

return:

onehitflag:
  dd 0

registersymbol(INJECT)
registersymbol(onehitflag)

[DISABLE]
INJECT:
  db F3 41 0F 11 45 10

unregistersymbol(INJECT)
unregistersymbol(onehitflag)
dealloc(newmem)
dealloc(onehitflag)

{
