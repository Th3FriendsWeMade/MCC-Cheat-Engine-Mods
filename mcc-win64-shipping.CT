      <CheatEntries>
        <CheatEntry>
          <ID>87795</ID>
          <Description>"Godmode"</Description>
          <Options moHideChildren="1"/>
          <LastState/>
          <Color>0080FF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
// Premier script
aobscanmodule(INJECT1,halo3odst.dll,F3 0F 11 86 EC 00 00 00 44)
alloc(newmem1,$1000,INJECT1)
alloc(onehitflag,4)
label(code1)
label(return1)
label(invincible1)
label(onehit1)
label(Zwtix1)
label(check_onehit1)

newmem1:
  cmp [rsi+16C],1
  je invincible1
  jmp check_onehit1

invincible1:
  jmp return1

check_onehit1:
  cmp dword ptr [onehitflag], 1
  je onehit1
  jmp code1

onehit1:
  movss xmm0,[Zwtix1]
  jmp code1

Zwtix1:
  dd (float)-1

code1:
  movss [rsi+000000EC],xmm0
  jmp return1

INJECT1:
  jmp newmem1
  nop 3

return1:

onehitflag:
  dd 0

registersymbol(INJECT1)
registersymbol(onehitflag)

// Deuxième script
aobscanmodule(INJECT2,halo3odst.dll,F3 0F 11 8F E8 00 00 00)
alloc(newmem2,$1000,INJECT2)
label(code2)
label(return2)
label(invincible2)
label(onehit2)
label(Zwtix2)
label(check_onehit2)

newmem2:
  cmp r11,1
  je check_onehit2
  jmp invincible2

check_onehit2:
  cmp dword ptr [onehitflag], 1
  je onehit2
  jmp code2

onehit2:
  movss xmm1,[Zwtix2]
  jmp code2

Zwtix2:
  dd (float)-1

invincible2:
  jmp return2

code2:
  movss [rdi+000000E8],xmm1
  jmp return2

INJECT2:
  jmp newmem2
  nop 3

return2:

registersymbol(INJECT2)

[DISABLE]
INJECT1:
  db F3 0F 11 86 EC 00 00 00
unregistersymbol(INJECT1)
unregistersymbol(onehitflag)
dealloc(newmem1)
dealloc(onehitflag)

INJECT2:
  db F3 0F 11 8F E8 00 00 00
unregistersymbol(INJECT2)
dealloc(newmem2)

</AssemblerScript>
