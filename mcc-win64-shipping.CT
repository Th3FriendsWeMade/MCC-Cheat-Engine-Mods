          <AssemblerScript>[ENABLE]
// Premier script (Godmode et One Hit Kill)
aobscanmodule(INJECT1,halo2.dll,F3 0F 11 8F EC 00 00 00)
alloc(newmem1,$1000,INJECT1)
alloc(onehitflag,4)
label(code1)
label(return1)
label(infinitehealth)
label(kill)
label(Zwtix)
label(check_onehit)

newmem1:
  cmp dword ptr [rdi+410], 1
  je infinitehealth
  jmp check_onehit

check_onehit:
  cmp dword ptr [onehitflag], 1
  je kill
  jmp code1

infinitehealth:
  jmp return1

kill:
  movss xmm1, [Zwtix]
  jmp code1


Zwtix:
  dd (float)-1

code1:
  movss [rdi+000000EC], xmm1
  jmp return1

INJECT1:
  jmp newmem1
  nop 3

return1:

onehitflag:
  dd 0

registersymbol(INJECT1)
registersymbol(onehitflag)

// Deuxième script (Shield Control)
aobscanmodule(INJECT2,halo2.dll,F3 41 0F 10 85 F0 00 00 00 EB)
alloc(newmem2,$1024,INJECT2)
label(code2)
label(return2)

newmem2:
  cmp dword ptr [r13+410], 1
  je code2
  mov dword ptr [r13+F0], 0
  movss xmm0, [r13+000000F0]
  jmp return2

code2:
  movss xmm0, [r13+000000F0]
  jmp return2

INJECT2:
  jmp newmem2
  nop 4

return2:

registersymbol(INJECT2)

[DISABLE]
