// Premier script
aobscanmodule(INJECT1,halo3.dll,F3 0F 11 8F F4 00 00 00)
alloc(newmem1,$1000,INJECT1)
alloc(onehitflag,4)
label(code1)
label(return1)
label(check_onehit1)

newmem1:
  cmp [rdi+90],1
  je invincible1
  jmp check_onehit1

invincible1:
  jmp return1

check_onehit1:
  cmp dword ptr [onehitflag], 1
  je onehit1
  jmp code1

onehit1:
  movss xmm1, [Zwtix1]
  jmp code1

Zwtix1:
  dd (float)-1

code1:
  movss [rdi+000000F4],xmm1
  jmp return1

INJECT1:
  jmp newmem1
  nop 3

return1:

onehitflag:
  dd 0

