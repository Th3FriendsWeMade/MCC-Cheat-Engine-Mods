  db F3 0F 11 8F EC 00 00 00
unregistersymbol(INJECT1)
unregistersymbol(onehitflag)
dealloc(newmem1)
dealloc(onehitflag)

INJECT2:
  db F3 41 0F 10 85 F0 00 00 00
unregistersymbol(INJECT2)
dealloc(newmem2)

</AssemblerScript>
