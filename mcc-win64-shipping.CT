</AssemblerScript>
          <CheatEntries>
            <CheatEntry>
              <ID>87978</ID>
              <Description>"One hit kill"</Description>
              <LastState/>
              <Color>00FFFF</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
onehitflag:
  dd 1

[DISABLE]
onehitflag:
  dd 0

</AssemblerScript>
            </CheatEntry>
            <CheatEntry>
              <ID>97725</ID>
              <Description>"READ ME ---------&gt;"</Description>
              <LastState/>
              <Color>00FFFF</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>//Hello, I know it might sound strange, but for the godmode to activate, you need to take
//damage first.
//Even after the cutscenes, make sure to get hit by a projectile or graze your grenade,
//but don't stick yourself to a sticky bomb if your shield bar isn't yellow.
//Have a good evening and a great life!































































[enable]
[disable]
</AssemblerScript>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>
        <CheatEntry>
          <ID>87642</ID>
          <Description>"Ai don't see you"</Description>
          <LastState/>
          <Color>FF0080</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
// Premier scan
aobscanmodule(INJECT1,haloreach.dll,41 0F 10 00 48 8B D7)
alloc(newmem1,$1000,INJECT1)

newmem1:
  nop
  nop
  nop
  nop
  nop
  nop
  nop
  jmp return1

INJECT1:
  jmp newmem1
  nop 2

return1:

registersymbol(INJECT1)

// Deuxième scan
aobscanmodule(INJECT2,haloreach.dll,0F 10 07 48 8B D3 0F)
alloc(newmem2,$1000,INJECT2)

newmem2:
  nop
  nop
  nop
  nop
  nop
  nop
  jmp return2

INJECT2:
  jmp newmem2
  nop

return2:

registersymbol(INJECT2)

[DISABLE]
INJECT1:
  db 41 0F 10 00 48 8B D7
unregistersymbol(INJECT1)
dealloc(newmem1)

INJECT2:
  db 0F 10 07 48 8B D3
unregistersymbol(INJECT2)
dealloc(newmem2)

</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>87987</ID>
          <Description>"Ai can't fire"</Description>
          <LastState/>
          <Color>FF0080</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{ Game   : MCCWinStore-Win64-Shipping.exe
  Version: 
  Date   : 2024-08-16
  Author : Nathan

  This script does blah blah blah
}

[ENABLE]

aobscanmodule(INJECT,haloreach.dll,0F 10 4A 10 0F 11 49 10) // should be unique
alloc(newmem,$1000,INJECT)

label(code)
label(return)

newmem:

code:
  nop
  nop
  nop
  nop
  jmp return

INJECT+09:
  jmp newmem
  nop 3
return:
registersymbol(INJECT)

[DISABLE]

INJECT+09:
  db 0F 10 4A 10 0F 11 49 10

unregistersymbol(INJECT)
dealloc(newmem)

