// Godmode &amp; One Hit Kill
aobscanmodule(INJECT1,halo1.dll,F3 0F 11 83 9C 00 00 00 EB)
alloc(newmem1,$1000,INJECT1)
alloc(onehitflag,4)
label(one_hit_kill)
label(return1)
label(kill)
label(code1)
label(check_onehit)

newmem1:
  cmp r10,5
  je invincible
  jmp check_onehit

check_onehit:
  cmp dword ptr [onehitflag], 1
  je one_hit_kill
  jmp code1

invincible:
jmp return1

one_hit_kill:
  movss xmm0,[kill]
  jmp code1

kill:
  dd (float)-1

code1:
  movss [rbx+0000009C], xmm0
  jmp return1

INJECT1:
  jmp newmem1
  nop 3

return1:

onehitflag:
  dd 0

registersymbol(INJECT1)
registersymbol(onehitflag)

// No Jump Damage
aobscanmodule(INJECT2,halo1.dll,41 F6 86 F4 02 00 00 80)
alloc(newmem2,$1000,INJECT2)
label(code2)
label(return2)

newmem2:
code2:
  and byte ptr [r14+000002F4], 7F
  jmp return2

INJECT2:
  jmp newmem2
  nop 3

return2:

registersymbol(INJECT2)

[DISABLE]
INJECT1:
  db F3 0F 11 83 9C 00 00 00
unregistersymbol(INJECT1)
unregistersymbol(onehitflag)
dealloc(newmem1)
dealloc(onehitflag)

INJECT2:
  db 41 F6 86 F4 02 00 00 80
unregistersymbol(INJECT2)
dealloc(newmem2)
</AssemblerScript>
