haloreach.dll+4DF215: 41 8B CF                 - mov ecx,r15d
haloreach.dll+4DF218: 40 88 74 24 20           - mov [rsp+20],sil
// ---------- INJECTING HERE ----------
haloreach.dll+4DF21D: F3 41 0F 11 45 10        - movss [r13+10],xmm0
// ---------- DONE INJECTING  ----------
haloreach.dll+4DF223: E8 00 38 00 00           - call haloreach.dll+4E2A28
haloreach.dll+4DF228: 48 8B 84 24 B0 00 00 00  - mov rax,[rsp+000000B0]
