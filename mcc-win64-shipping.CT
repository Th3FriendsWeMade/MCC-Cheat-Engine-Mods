  db F3 0F 11 8F F4 00 00 00
unregistersymbol(INJECT1)
unregistersymbol(onehitflag)
dealloc(newmem1)
dealloc(onehitflag)

INJECT2:
  db F3 0F 11 83 F8 00 00 00
unregistersymbol(INJECT2)
dealloc(newmem2)
</AssemblerScript>
