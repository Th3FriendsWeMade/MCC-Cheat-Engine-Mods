              <Description>"Increase Jump Height"</Description>
              <LastState/>
              <Color>FF0000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]

aobscanmodule(INJECT,halo1.dll,F3 0F 10 98 B4 03 00 00)
alloc(newmem,$1000,INJECT)

label(code)
label(return)
label(minClamp)
label(maxClamp)
label(multiplier)

newmem:

code:
  // load original value
  movss xmm0,[rax+000003B4]

  // scale it (your jump multiplier)
  mulss xmm0,[multiplier]

  // clamp low (prevents weird negative/zero physics)
  maxss xmm0,[minClamp]

  // clamp high (prevents engine breaking / mission issues)
  minss xmm0,[maxClamp]

  // write back (this is the "works but stable" part)
  movss [rax+000003B4],xmm0

  jmp return

multiplier:
  dd (float)2.5

minClamp:
  dd (float)0.8

maxClamp:
  dd (float)8.0

INJECT:
  jmp newmem
  nop 3

return:
registersymbol(INJECT)

[DISABLE]

INJECT:
  db F3 0F 10 98 B4 03 00 00

unregistersymbol(INJECT)
dealloc(newmem)
</AssemblerScript>
